{
  "name": "lilia-ui-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "perf:components:browser": "node tests/perf/componentPerformance.browser.mjs",
    "perf:components:light": "vitest run --config vitest.perf.config.ts",
    "perf:components:update-baseline": "node tests/perf/updateComponentPerformanceBaseline.mjs",
    "test:ui:browser": "node tests/ui/shellAppearance.browser.mjs",
    "typecheck": "yarn workspaces foreach -Ap run typecheck",
    "test": "vitest run",
    "verify": "yarn typecheck && yarn test && yarn test:ui:browser && yarn perf:components:light"
  },
  "devDependencies": {
    "@lucide/vue": "^1.17.0",
    "@playwright/test": "^1.61.1",
    "@tauri-apps/api": "^2.11.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/vue": "^8.1.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/compiler-sfc": "^3.5.35",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.8",
    "vue": "^3.5.35",
    "vue-router": "^5.1.0",
    "vue-tsc": "^3.3.4"
  },
  "packageManager": "yarn@4.14.1"
}
