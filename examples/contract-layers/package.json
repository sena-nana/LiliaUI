{
  "name": "@lilia/example-contract-layers",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "typecheck:lilia": "vue-tsc --noEmit -p tsconfig.lilia.json",
    "typecheck:nana": "vue-tsc --noEmit -p tsconfig.nana.json",
    "typecheck": "pnpm typecheck:lilia && pnpm typecheck:nana",
    "build:lilia": "cross-env UI_LAYER=lilia vite build",
    "build:nana": "cross-env UI_LAYER=nana vite build",
    "build": "pnpm build:lilia && pnpm build:nana",
    "check": "pnpm typecheck && pnpm build"
  },
  "dependencies": {
    "@lilia/nana-ui": "workspace:*",
    "@lilia/ui": "workspace:*",
    "@lilia/ui-contract": "workspace:*",
    "@lilia/ui-foundation": "workspace:*",
    "@lucide/vue": "^1.22.0",
    "@tauri-apps/api": "^2.11.1",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.8",
    "cross-env": "^10.1.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vue-tsc": "^3.3.7"
  }
}
