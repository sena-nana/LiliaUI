{
  "name": "@lilia/config",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.d.mts",
      "import": "./src/index.mjs"
    },
    "./app-config": {
      "types": "./src/app-config.d.mts",
      "import": "./src/app-config.mjs"
    },
    "./version": {
      "types": "./src/version.d.mts",
      "import": "./src/version.mjs"
    },
    "./tsconfig/app.json": "./tsconfig/app.json",
    "./tsconfig/node.json": "./tsconfig/node.json"
  },
  "scripts": {
    "typecheck": "node --check src/index.mjs && node --check src/app-config.mjs && pnpm run -T tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=26.0.0 <27"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^6.0.8",
    "vite": "^8.1.4",
    "vitepress": "^1.6.4",
    "vue": "^3.5.39"
  }
}
